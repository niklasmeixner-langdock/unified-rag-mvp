# --- HTTP API ---
PORT=3000
API_KEY=replace-with-strong-secret

# --- Postgres (metadata only — vectors are in Pinecone) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/unified_rag

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6380

# --- Microsoft Graph OAuth (single tenant) ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
MS_OAUTH_SCOPES=Sites.Read.All Files.Read.All offline_access User.Read

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX=unified-rag-mvp
PINECONE_NAMESPACE=customer-x

# --- Sync ---
SYNC_CRON=0 */2 * * *   # every 2 hours
EMBEDDING_BATCH_SIZE=128
